# AI Pentest Assistant Configuration
# Copy this to .env and adjust values

# DVWA Target
DVWA_BASE_URL=http://localhost:8080
DVWA_USERNAME=admin
DVWA_PASSWORD=password

# Security level: low, medium, high, impossible
DVWA_SECURITY=low

# Juice Shop Target
JUICESHOP_BASE_URL=http://localhost:3000

# Training
MAX_STEPS_PER_EPISODE=50
TRAINING_EPISODES=5000

# Logging
LOG_DIR=./logs
MODEL_DIR=./models
TENSORBOARD_DIR=./logs/tensorboard

# Admin — error log viewer  (/admin <password> inside the assistant)
# Change this to a strong password before deployment
ASSISTANT_ADMIN_PASSWORD=changeme

# LLM (Phase 3 - Optional)
# OLLAMA_URL=http://localhost:11434
# LLM_MODEL=mistral
